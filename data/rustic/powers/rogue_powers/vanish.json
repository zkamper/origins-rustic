{
    "type": "apoli:multiple",
    "activate": {
        "type": "apoli:active_self",
        "entity_action": {
            "type": "apoli:apply_effect",
            "effects": [
                {
                    "effect": "minecraft:invisibility",
                    "duration": 80,
                    "amplifier": 0,
                    "show_particles": false
                },
                {
                    "effect": "minecraft:speed",
                    "duration": 80,
                    "amplifier": 1,
                    "show_particles": false
                }
            ]
        },
        "cooldown": 140,
        "key": {
            "key": "key.origins.primary_active"
        }
    },
    "tick": {
        "type": "apoli:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "apoli:if_else",
            "condition": {
                "type": "apoli:resource",
                "resource": "rustic:rogue_powers/vanish_activate",
                "comparison": ">",
                "compare_to": 0
            },
            "if_action": {
                "type": "apoli:change_resource",
                "resource": "rustic:rogue_powers/vanish_bar",
                "change": -1,
                "operation": "add"
            },
            "else_action": {
                "type": "apoli:if_else",
                "condition": {
                    "type": "apoli:resource",
                    "resource": "rustic:rogue_powers/vanish_bar",
                    "comparison": "<",
                    "compare_to": 4
                },
                "if_action": {
                    "type": "apoli:and",
                    "actions": [
                        {
                            "type": "apoli:change_resource",
                            "resource": "rustic:rogue_powers/vanish_bar",
                            "change": 4,
                            "operation": "set"
                        },
                        {
                            "type": "origins:play_sound",
                            "sound": "minecraft:item.armor.equip_chain",
                            "player": true
                        }
                    ]

                }

            }
        }
    },
    "hide_armor": {
        "type": "apoli:prevent_feature_render",
        "features": [
            "armor",
            "held_item",
            "elytra"
        ],
        "condition": {
            "type": "apoli:status_effect",
            "effect": "minecraft:invisibility"
        }
    },
    "damage_bonus": {
        "type": "apoli:modify_damage_dealt",
        "condition": {
            "type": "apoli:resource",
            "resource": "rustic:rogue_powers/vanish_activate",
            "comparison": ">",
            "compare_to": 60
        }
    },
    "overlay": {
        "type": "apoli:overlay",
        "texture": "minecraft:textures/misc/nausea.png",
        "red": 0.2,
        "green": 0.2,
        "blue": 0.6,
        "strength": 0.6,
        "draw_mode": "nausea",
        "draw_phase": "above_hud",
        "visible_in_third_person": true,
        "hide_with_hud": false,
        "condition": {
            "type": "apoli:resource",
            "resource": "rustic:rogue_powers/vanish_activate",
            "comparison": ">",
            "compare_to": 60
        }
    },
    "silent_step": {
        "type": "apoli:prevent_game_event",
        "event": "minecraft:step",
        "condition": {
            "type": "apoli:resource",
            "resource": "rustic:rogue_powers/vanish_activate",
            "comparison": ">",
            "compare_to": 60
        }
    },
    "break_invisibility_on_hit": {
        "type": "apoli:action_on_hit",
        "bientity_action": {
            "type": "apoli:actor_action",
            "action": {
                "type":"apoli:and",
                "actions": [
                    {
                        "type": "apoli:clear_effect",
                        "effect": "minecraft:invisibility"
                    },
                    {
                        "type": "apoli:clear_effect",
                        "effect": "minecraft:speed"
                    },
                    {
                        "type": "apoli:change_resource",
                        "resource": "rustic:vanish_bar",
                        "operation": "set",
                        "value": 0
                    }
                ]
            }
        },
        "condition": {
            "type": "apoli:status_effect",
            "effect": "minecraft:invisibility"
        }
    },
    "name": "Vanish",
    "description": "Your expertise in stealth allows you to briefly turn invisible and gain a burst of speed."
}